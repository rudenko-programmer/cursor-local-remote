{
  "name": "cursor-local-remote",
  "version": "0.1.0",
  "type": "module",
  "description": "Control Cursor IDE from any device on your local network",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jon-makinen/cursor-local-remote.git"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "remote",
    "ai",
    "agent",
    "cli",
    "mobile"
  ],
  "bin": {
    "cursor-local-remote": "./bin/cursor-remote.mjs",
    "clr": "./bin/cursor-remote.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "public/",
    ".next/server/",
    ".next/static/",
    ".next/*.json",
    ".next/BUILD_ID",
    ".next/package.json",
    "next.config.ts",
    "tsconfig.json",
    "postcss.config.mjs"
  ],
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3100",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3100",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && rm -f .next/server/**/*.map"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "highlight.js": "^11.11.1",
    "next": "^15.5.12",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "web-haptics": "^0.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20"
  }
}
