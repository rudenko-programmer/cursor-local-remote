{
  "name": "cursor-remote-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Control Cursor IDE from any device on your local network",
  "bin": {
    "cursor-remote": "./bin/cursor-remote.mjs"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "remote": "node bin/cursor-remote.mjs",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  }
}
